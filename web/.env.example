# Chaves do Supabase — copie do painel do Supabase:
# Project Settings -> API
#
# Crie um arquivo ".env.local" (para rodar localmente) com estes dois valores,
# e coloque os mesmos valores na Vercel (Settings -> Environment Variables).

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui
